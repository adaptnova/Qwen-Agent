# Nova Environment Configuration Template
# Copy this file to /data/secrets/nova.env and fill in your actual values

# ==============================================================================
# REQUIRED: Hugging Face Configuration
# ==============================================================================
# Get your token from https://huggingface.co/settings/tokens
export HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# ==============================================================================
# Coder LLM Configuration (Port 18010)
# ==============================================================================
# vLLM coder endpoint - adjust IP if running on different host
export NOVA_CODER_LLM_SERVER=http://10.0.1.1:18010/v1
export NOVA_CODER_LLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct-FP8

# ==============================================================================
# Generalist LLM Configuration (Port 18000)
# ==============================================================================
# vLLM generalist endpoint - adjust IP if running on different host
export NOVA_LLM_SERVER=http://10.0.1.1:18000/v1
export NOVA_LLM_MODEL=Qwen/Qwen3-VL-30B-A3B-Thinking-FP8

# ==============================================================================
# Workspace Configuration
# ==============================================================================
# Default workspace for Nova operations
export QWEN_AGENT_DEFAULT_WORKSPACE=/data/nova

# ==============================================================================
# Optional: Database Configuration (if using sql_tool)
# ==============================================================================
# PostgreSQL main database
# export POSTGRES_MAIN_HOST=localhost
# export POSTGRES_MAIN_PORT=5432
# export POSTGRES_MAIN_USER=nova
# export POSTGRES_MAIN_PASSWORD=your_password_here
# export POSTGRES_MAIN_DATABASE=nova

# ==============================================================================
# Optional: External API Keys (if using web_researcher)
# ==============================================================================
# Serper for web search
# export SERPER_API_KEY=your_serper_key_here

# ==============================================================================
# Optional: Redis Configuration (if using caching)
# ==============================================================================
# export REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# Optional: Logging Configuration
# ==============================================================================
# Log levels: DEBUG, INFO, WARNING, ERROR
# export NOVA_LOG_LEVEL=INFO

# ==============================================================================
# Optional: Performance Tuning
# ==============================================================================
# Max parallel function calls (0 = unlimited)
# export NOVA_MAX_PARALLEL_CALLS=5

# Request timeout in seconds
# export NOVA_REQUEST_TIMEOUT=120

# ==============================================================================
# Development Settings (comment out in production)
# ==============================================================================
# export NOVA_DEBUG=true
# export NOVA_MOCK_TOOLS=false